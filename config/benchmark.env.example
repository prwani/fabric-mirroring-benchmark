# Azure deployment
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-fabric-pg-mirror-bench
AZURE_LOCATION=swedencentral
DEPLOYMENT_NAME=fabric-pg-mirror-bench
# Optional JSON object passed to the public Azure SQL template.
CUSTOM_TAGS={}
APPLY_CUSTOM_TAGS_TO_AZURE_SQL=true
APPLY_CUSTOM_TAGS_TO_BENCHMARK_VM=true
APPLY_CUSTOM_TAGS_TO_FABRIC_CAPACITY=true
APPLY_CUSTOM_TAGS_TO_NETWORKING=true
APPLY_CUSTOM_TAGS_TO_MONITORING=true

# Naming
PROJECT_NAME=fpmb
SOURCE_TYPE=postgresql
ADMIN_OBJECT_ID=
ADMIN_UPN=
CURRENT_CLIENT_IP_ADDRESS=

# PostgreSQL
POSTGRES_ADMIN_USER=pgadmin
POSTGRES_ADMIN_PASSWORD=
POSTGRES_DATABASE=tprocc
POSTGRES_VERSION=16
POSTGRES_SKU_NAME=Standard_D2ds_v5
POSTGRES_SKU_TIER=GeneralPurpose
POSTGRES_STORAGE_GB=128
POSTGRES_ENABLE_ENTRA_AUTH=true
POSTGRES_ENTRA_ADMIN_NAME=
POSTGRES_ENTRA_ADMIN_OBJECT_ID=
POSTGRES_ENTRA_ADMIN_PRINCIPAL_TYPE=User

# MySQL (used when SOURCE_TYPE=mysql)
MYSQL_ADMIN_USER=mysqladmin
MYSQL_ADMIN_PASSWORD=
MYSQL_DATABASE=tprocc
MYSQL_VERSION=8.0.21
MYSQL_SKU_NAME=Standard_D2ds_v4
MYSQL_STORAGE_GB=128

# Azure SQL Database / SQL MI (used when SOURCE_TYPE=azure-sql-db or sql-mi)
SQL_ENTRA_ADMIN_LOGIN=
SQL_ENTRA_ADMIN_OBJECT_ID=
AZURE_SQL_ADMIN_USER=sqladmin
AZURE_SQL_ADMIN_PASSWORD=
AZURE_SQL_AAD_ONLY_AUTH=true
AZURE_SQL_AUTH_MODE=entra
AZURE_SQL_MSI_OBJECT_ID=
AZURE_SQL_SERVER_NAME=
AZURE_SQL_SERVER_PRINCIPAL_ID=
AZURE_SQL_DATABASE=tprocc
AZURE_SQL_TPROC_C_DATABASE=tprocc
AZURE_SQL_HOST=
AZURE_SQL_PORT=1433
AZURE_SQL_SKU_NAME=GP_Gen5_4
AZURE_SQL_SKU_TIER=GeneralPurpose
AZURE_SQL_SKU_FAMILY=Gen5
AZURE_SQL_SKU_CAPACITY=4
AZURE_SQL_MAX_SIZE_BYTES=34359738368
AZURE_SQL_SQLCMD_ARGS=-C -S your-server.database.windows.net -d tprocc -G
AZURE_SQL_FABRIC_LOGIN=fabric_login
AZURE_SQL_FABRIC_PASSWORD=
AZURE_SQL_HAMMERDB_LOGIN=hammerdb
AZURE_SQL_HAMMERDB_PASSWORD=
AZURE_SQL_TPROC_C_USE_BCP=false

# SQL Server on Azure VM (used when SOURCE_TYPE=sql-server)
SQL_SERVER_VM_ADMIN_USERNAME=azureuser
SQL_SERVER_VM_ADMIN_PASSWORD=

# Fabric
FABRIC_CAPACITY_SKU=F8
FABRIC_WORKSPACE_NAME=fpmb-benchmark
FABRIC_MIRRORED_DATABASE_NAME=tprocc-mirror
FABRIC_WORKSPACE_ID=
FABRIC_MIRRORED_DATABASE_ID=
FABRIC_CONNECTION_ID=
# Set true only when creating a new Fabric cloud SQL connection through the REST API.
FABRIC_CREATE_CONNECTION=false
FABRIC_CONNECTION_DISPLAY_NAME=azure-sql-tprocc-mirroring
# Optional deployment prerequisite for a new Azure SQL source service principal.
PROVISION_FABRIC_SOURCE_APP=false
FABRIC_SOURCE_APP_NAME=
FABRIC_SOURCE_APP_SECRET_VALIDITY_DAYS=7
FABRIC_SOURCE_APP_ENV_OUTPUT=results/fabric-source-app.env
# Requires a tenant administrator that can assign directory roles. Needed for
# Azure SQL to resolve the source service principal while creating its login.
ASSIGN_AZURE_SQL_SERVER_DIRECTORY_READERS=false
FABRIC_SOURCE_TENANT_ID=
FABRIC_SOURCE_SERVICE_PRINCIPAL_CLIENT_ID=
# Prefer the Fabric Key Vault connection reference instead of supplying a secret.
FABRIC_SOURCE_SERVICE_PRINCIPAL_SECRET=
FABRIC_KEY_VAULT_CONNECTION_ID=
FABRIC_KEY_VAULT_SECRET_NAME=
FABRIC_KEY_VAULT_SECRET_VERSION=
# Contributor is a workspace-level permission for the Azure SQL logical-server identity.
# Keep false unless the tenant has approved this broader alternative to portal item permission.
FABRIC_GRANT_AZURE_SQL_SERVER_MI_WORKSPACE_CONTRIBUTOR=false
FABRIC_MIRROR_DEFAULT_SCHEMA=dbo
FABRIC_MIRROR_TABLES=dbo.warehouse,dbo.district,dbo.customer,dbo.history,dbo.orders,dbo.new_order,dbo.order_line,dbo.stock,dbo.item,dbo.fabric_cdc_latency_marker
FABRIC_SQL_ANALYTICS_ENDPOINT_ID=
FABRIC_SQL_ANALYTICS_ENDPOINT_CONNECTION_STRING=
FABRIC_SQL_ANALYTICS_DATABASE=
# Assign the benchmark VM managed identity Fabric Viewer to run noninteractive
# SQL analytics endpoint validation through ODBC/MSI.
FABRIC_GRANT_BENCHMARK_VM_WORKSPACE_VIEWER=false
FABRIC_ODBC_SERVER=
FABRIC_DATABASE=tprocc
FABRIC_SQLCMD_ARGS=-C -S your-fabric-sql-endpoint.datawarehouse.fabric.microsoft.com -d your_mirrored_database -G
FABRIC_SETUP_OUTPUT=results/fabric-mirror-setup.json
FABRIC_SETUP_ENV_OUTPUT=results/fabric-mirror-setup.env
FABRIC_SQL_ENDPOINT_PROVISION_TIMEOUT_SECONDS=900
FABRIC_SQL_ENDPOINT_REFRESH_TIMEOUT_MINUTES=15
FABRIC_SQL_ENDPOINT_REFRESH_OPERATION_TIMEOUT_SECONDS=1200
FABRIC_SQL_ENDPOINT_REFRESH_FILE=results/fabric-sql-endpoint-refresh.json
FABRIC_MARKER_TABLE=dbo.fabric_cdc_latency_marker
FABRIC_SCHEMA=dbo

# HammerDB / benchmark
HAMMERDB_VERSION=5.0
TPROC_C_DATABASE=tprocc
TPROC_C_USER=tprocc
# Defaults to PGPASSWORD if unset. Set a separate value for repeatable runs.
TPROC_C_PASSWORD=
TPROC_C_WAREHOUSES=10
TPROC_C_BUILD_VUSERS=4
TPROC_C_VUSERS=8
TPROC_C_RAMPUP_MINUTES=2
TPROC_C_DURATION_MINUTES=10
TPROC_C_TOTAL_ITERATIONS=10000000
TPROC_C_ALL_WAREHOUSE=true
CDC_MARKER_BATCHES=60
CDC_MARKER_INTERVAL_SECONDS=5
CDC_POLL_INTERVAL_SECONDS=5
CDC_BULK_OPERATION=insert
CDC_BULK_BATCH_SIZE=500
CDC_BULK_BATCHES=3
CDC_BULK_PAYLOAD_BYTES=256
CDC_BULK_TIMEOUT_SECONDS=1800
STOCK_UPDATE_BATCH_SIZE=100000
STOCK_UPDATE_PAYLOAD_BYTES=128
STOCK_UPDATE_TIMEOUT_SECONDS=3600
STOCK_UPDATE_RESULTS_FILE=results/stock-bulk-update.csv
FABRIC_STOCK_TABLE=dbo.stock
NEW_TABLE_TEST_ROWS=1000
NEW_TABLE_TEST_TIMEOUT_SECONDS=1800
NEW_TABLE_TEST_RESULTS_FILE=results/new-table-auto-replication.csv
MIRRORED_TABLES=public.warehouse,public.district,public.customer,public.history,public.orders,public.new_order,public.order_line,public.stock,public.item,public.fabric_cdc_latency_marker

# Shared benchmark VM output
BENCHMARK_VM_NAME=
